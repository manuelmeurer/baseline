-# frozen_string_literal: true

- if Baseline::Current.tailwind
  %dialog#modal-container.modal{ data: @stimco.to_h }
    .modal-box{ data: @stimco.target(:dialog) }
      .flex.justify-between.items-center{ data: @stimco.target(:header) }
        %h3.font-bold{ data: @stimco.target(:title) }
        .flex.gap-2{ data: @stimco.target(:actions) }
        %button.btn.btn-sm.btn-circle.btn-ghost{ type: "button", data: { action: "modal#close" } } ✕
      %div{ data: @stimco.target(:body) }
        = helpers.turbo_frame_tag :modal, data: @stimco.target(:frame), target: "_top"
      .modal-action{ data: @stimco.target(:footer) }
    %form.modal-backdrop{ method: "dialog" }
      %button close
- else
  #modal-container.modal.fade{ data: @stimco.to_h }
    .modal-dialog.modal-fullscreen-sm-down{ data: @stimco.target(:dialog) }
      .modal-content{ data: @stimco.target(:content) }
        .modal-header{ data: @stimco.target(:header) }
          %h5.modal-title{ data: @stimco.target(:title) }
          .d-flex.gap-2.mx-3{ data: @stimco.target(:actions) }
          %button.btn-close{ type: "button", data: { bs_dismiss: "modal" } }
        .modal-body{ data: @stimco.target(:body) }
          = helpers.turbo_frame_tag :modal, data: @stimco.target(:frame), target: "_top"
        .modal-footer{ data: @stimco.target(:footer) }
