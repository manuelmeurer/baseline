-# frozen_string_literal: true

%header.flex.items-start.justify-between.gap-4.mb-6.pb-4.border-b.border-slate-200{ class: @css_class }
  %h1.text-2xl.font-semibold.tracking-tight
    = @title
  - if @subtitle
    %p.mt-1.text-sm.text-slate-500
      = @subtitle
  - if actions?
    .flex.items-center.gap-2
      = actions
