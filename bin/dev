#!/usr/bin/env bash

# Load env files explicitly and set OVERMIND_SKIP_ENV to skip Overmind's
# automatic .env loading, which uses godotenv.Overload (clobbering our
# shell-sourced values) and does not support variable substitution
# (e.g. FOO=${BAR}).
set -a
[ -f .env.development ] && source .env.development
[ -f .env ] && source .env
[ -f .env.worktree-manager ] && source .env.worktree-manager
set +a

OVERMIND_SKIP_ENV=1 exec overmind start -f Procfile.dev "$@"
