#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/inline"
require "fileutils"

gemfile do
  source "https://rubygems.org"
  gem "thor"
end

class Setup < Thor
  include Thor::Actions

  default_command :setup

  def self.exit_on_failure? = true

  desc "setup", "Set up the project"
  def setup
    run("bundle check") || run("bundle install")

    setup_worktree_manager

    run "RAILS_ENV=development #{rails} db:prepare", abort_on_failure: true
    run "RAILS_ENV=test #{rails} parallel:prepare", abort_on_failure: true
    run "#{rails} log:clear tmp:clear", abort_on_failure: true
  end

  private

    def rails = File.join(Dir.pwd, "bin/rails")

    def setup_worktree_manager
      if app_root = ENV["CONDUCTOR_ROOT_PATH"] || ENV["SUPERSET_ROOT_PATH"]
        symlink_from_app_root \
          app_root,
          ".bundle",
          "config/master.key"
      end
    end

    def symlink_from_app_root(app_root, *paths)
      paths.each do |path|
        source = File.join(app_root, path)
        next unless File.exist?(source)

        if File.exist?(path)
          return if File.symlink?(path)
          abort "Error: #{path} exists and is not a symlink. Remove it manually first."
        end

        say "Symlinking #{path} from #{source}..."
        FileUtils.mkdir_p(File.dirname(path))
        FileUtils.ln_s(source, path)
      end
    end
end

Setup.start(ARGV)
