#!/usr/bin/env bash

DEFAULT_PORT=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --default-port=*) DEFAULT_PORT="${1#*=}" ;;
    --default-port)   DEFAULT_PORT="$2"; shift ;;
  esac
  shift
done

if [ -z "$CONDUCTOR_PORT" ] && [ -z "$DEFAULT_PORT" ]; then
  echo "Usage: bin/env --default-port=<port>" >&2
  exit 1
fi
export PORT=${CONDUCTOR_PORT:-${PORT:-$DEFAULT_PORT}}

if [ -n "$CONDUCTOR_WORKSPACE_NAME" ]; then
  export DB_NAME_SUFFIX="conductor_${CONDUCTOR_WORKSPACE_NAME}"
fi
