#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/inline"

gemfile do
  source "https://rubygems.org"
  gem "thor"
end

require "digest/md5"
require "json"

class Build < Thor
  include Thor::Actions

  default_command :build

  def self.exit_on_failure? = true

  desc "build", "build"
  def build
    bundle "install -j $(nproc)"

    # It shouldn't actually to call dartsass:build and tailwindcss:build explicitly,
    # since they should be run automatically before assets:precompile,
    # but on Hatchbox this does not work for some reason.
    %w[dartsass tailwindcss].each do |css_tool|
      if File.read("Gemfile.lock").include?("#{css_tool}-rails")
        puts "Running #{css_tool} build task..."
        bundle "exec rails #{css_tool}:build"
      end
    end

    bundle "exec rails assets:precompile"

    if ENV.key?("CRON")
      bundle "exec rails db:migrate"
    end

    bundle "clean"
  end

  private

    def bundle(cmd, capture: false)
      run("asdf exec bundle #{cmd}", capture:).then {
        capture ? _1.chomp : _1
      }
    end
end

Build.start(ARGV)
