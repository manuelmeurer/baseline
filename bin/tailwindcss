#!/usr/bin/env ruby
# frozen_string_literal: true

# Processes .css.erb templates from both the host app's app/assets/tailwind/
# and baseline's lib/baseline/tailwind/, then runs tailwindcss for each
# resulting .css input file. Build output goes to the host's app/assets/builds/.
#
# Usage:
#   bin/tailwindcss            # one-time build
#   bin/tailwindcss -w         # watch mode
#   bin/tailwindcss --minify   # minified build (production)

require "bundler/setup"
require "erb"
require "tailwindcss/ruby"

# baseline_path is used in the ERB templates to reference files in the gem.
baseline_path = Gem.loaded_specs["baseline"].full_gem_path

HOST_TAILWIND_DIR = "app/assets/tailwind"
GEM_TAILWIND_DIR  = File.join(baseline_path, "lib/baseline/tailwind")
BUILDS_DIR        = "app/assets/builds"
TEMPLATE_DIRS     = [HOST_TAILWIND_DIR, GEM_TAILWIND_DIR].freeze

# Process .css.erb templates into .css files (rendered alongside their template).
render_erb_templates = -> do
  TEMPLATE_DIRS.each do |dir|
    Dir.glob("#{dir}/*.css.erb").each do |template_path|
      output_path = template_path.delete_suffix(".erb")
      result = ERB.new(File.read(template_path)).result(binding)
      File.write(output_path, result)
    end
  end
end

# 1. Initial ERB rendering
render_erb_templates.call

# 2. Collect all CSS input files (skip rendered duplicates by basename)
input_files = TEMPLATE_DIRS
  .flat_map { Dir.glob("#{_1}/*.css") }
  .uniq { File.basename(_1) }
  .sort

if input_files.empty?
  abort "No CSS input files found in #{TEMPLATE_DIRS.join(' or ')}"
end

# 3. Run tailwindcss for each input file
exe    = Tailwindcss::Ruby.executable
watch  = ARGV.include?("-w")
minify = ARGV.include?("--minify")

pids = input_files.map do |input|
  name   = File.basename(input, ".css")
  output = "#{BUILDS_DIR}/#{name}.css"

  cmd = [exe, "-i", input, "-o", output]
  cmd << "--minify" if minify
  cmd << "-w" if watch

  puts "tailwindcss: #{name}.css"
  spawn(*cmd)
end

# 4. In watch mode, re-render .css.erb templates on change
if watch
  require "listen"

  TEMPLATE_DIRS.each do |dir|
    next unless Dir.exist?(dir)

    Listen.to(dir, only: %r{\.css\.erb$}) do |modified, added, removed|
      changed = [*modified, *added].map { File.basename(_1) }.join(", ")
      puts "re-rendering .css.erb templates (#{changed})"
      render_erb_templates.call
    end.start
  end
end

# Forward signals to child processes
%w[INT TERM].each do |signal|
  Signal.trap(signal) do
    pids.each { |pid| Process.kill(signal, pid) rescue nil }
  end
end

pids.each { |pid| Process.wait(pid) }
