-# frozen_string_literal: true

%html
  %head
    %meta{ charset: "utf-8" }
    = javascript_include_tag "https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"
    :css
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');
      body { font-family: "Inter", sans-serif; margin: 0; padding: 0; }
    = yield :head
  %body.bg-gray-900.p-8.pt-12.flex.flex-col.items-center.gap-8
    = yield
