-# frozen_string_literal: true

= render "baseline/admin/jobs/shared/header",
  title: @worker.name,
  subtitle: @worker.hostname

.mb-6
  = link_to "Back to workers",
    workers_path,
    class: "btn btn-sm btn-ghost"

.grid.gap-6{ class: "lg:grid-cols-2" }
  .card.bg-base-100.shadow-sm
    .card-body
      %h2.card-title
        Configuration
      %pre.mt-3.overflow-x-auto.rounded-lg.bg-base-200.p-4.text-xs
        = JSON.pretty_generate(@worker.configuration || {})
  .card.bg-base-100.shadow-sm
    .card-body
      %h2.card-title
        Raw data
      %pre.mt-3.overflow-x-auto.rounded-lg.bg-base-200.p-4.text-xs
        = JSON.pretty_generate(@worker.raw_data || {})
