-# frozen_string_literal: true

%header.flex.items-start.justify-between.gap-4.mb-6
  %div
    = link_to "Back", issues_path, class: "text-sm font-medium text-zinc-600 hover:text-zinc-900"
    %h1.mt-3.text-3xl.font-semibold
      = @issue.class_name
    %p.mt-2.max-w-4xl.whitespace-pre-wrap.text-zinc-700
      = @issue.message
  - if @issue.resolved?
    = button_to "Mark unresolved", unresolve_issue_path(@issue), class: "rounded-lg bg-zinc-900 px-4 py-2 text-sm font-medium text-white"
  - else
    = button_to "Resolve", resolve_issue_path(@issue), class: "rounded-lg bg-zinc-900 px-4 py-2 text-sm font-medium text-white"

.grid.gap-6{ class: "lg:grid-cols-[minmax(0,2fr),minmax(18rem,1fr)]" }
  .space-y-6
    .rounded-xl.bg-white.p-5.shadow-sm.ring-1.ring-zinc-200
      %h2.text-lg.font-semibold
        Backtrace
      %pre.mt-4.overflow-x-auto.rounded-lg.bg-zinc-950.p-4.text-xs.leading-6.text-zinc-100
        = @issue.backtrace.join("\n")

    - if @issue.causes.any?
      .rounded-xl.bg-white.p-5.shadow-sm.ring-1.ring-zinc-200
        %h2.text-lg.font-semibold
          Cause chain
        .mt-4.space-y-4
          - @issue.causes.each do |cause|
            .rounded-lg.border.border-zinc-200.p-4
              .font-medium.text-zinc-900
                = cause.fetch("class_name")
              %p.mt-1.whitespace-pre-wrap.text-sm.text-zinc-700
                = cause.fetch("message")
              - if cause.fetch("backtrace").any?
                %pre.mt-3.overflow-x-auto.rounded-lg.bg-zinc-950.p-4.text-xs.leading-6.text-zinc-100
                  = cause.fetch("backtrace").join("\n")

  .space-y-6
    .rounded-xl.bg-white.p-5.shadow-sm.ring-1.ring-zinc-200
      %h2.text-lg.font-semibold
        Metadata
      .mt-4.space-y-3.text-sm
        %div
          .font-medium.text-zinc-500
            Fingerprint
          .mt-1.break-all.text-zinc-900
            = @issue.fingerprint
        %div
          .font-medium.text-zinc-500
            Occurrences
          .mt-1.break-all.text-zinc-900
            = @issue.occurrences_count
        %div
          .font-medium.text-zinc-500
            First seen
          .mt-1.break-all.text-zinc-900
            = l @issue.first_seen_at, format: :default
        %div
          .font-medium.text-zinc-500
            Last seen
          .mt-1.break-all.text-zinc-900
            = l @issue.last_seen_at, format: :default
        %div
          .font-medium.text-zinc-500
            Resolved at
          .mt-1.break-all.text-zinc-900
            = @issue.resolved_at ? l(@issue.resolved_at, format: :default) : "-"

    .rounded-xl.bg-white.p-5.shadow-sm.ring-1.ring-zinc-200
      %h2.text-lg.font-semibold
        Context
      %pre.mt-4.overflow-x-auto.rounded-lg.bg-zinc-950.p-4.text-xs.leading-6.text-zinc-100
        = JSON.pretty_generate(@issue.context)
