-# frozen_string_literal: true
-# locals: ()

- if data = @email_delivery.deliverable.try(:add_to_calendar_data)
  %mj-divider
  %mj-social
    %mj-social-element{ "icon-size": "0px" }
      = t :add_to_calendar
    - data.each do |calendar_type, _data|
      %mj-social-element{ src: _data.fetch(:image_url), href: _data.fetch(:url), "icon-padding": "0 10px" }
