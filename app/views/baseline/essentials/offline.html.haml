-# frozen_string_literal: true

- i18n_scope = %i[essentials offline]

!!!

%html{ lang: I18n.locale }
  %head
    %meta{ charset: "utf-8" }
    %meta{ name: "viewport", content: "width=device-width, initial-scale=1" }
    %title
      = t :headline, scope: i18n_scope
    :css
      :root {
        color-scheme: light dark;
        --bg: #ffffff;
        --fg: #1a1a1a;
        --muted: #555555;
        --accent: #2563eb;
        --accent-fg: #ffffff;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0f0f0f;
          --fg: #f5f5f5;
          --muted: #a0a0a0;
          --accent: #3b82f6;
          --accent-fg: #ffffff;
        }
      }
      * { box-sizing: border-box; }
      html, body { height: 100%; margin: 0; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        line-height: 1.5;
      }
      main {
        max-width: 32rem;
        text-align: center;
      }
      h1 {
        font-size: 1.875rem;
        margin: 0 0 1rem;
      }
      p {
        color: var(--muted);
        margin: 0 0 2rem;
      }
      button {
        background: var(--accent);
        color: var(--accent-fg);
        border: 0;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font: inherit;
        font-weight: 600;
        cursor: pointer;
      }
      button:hover { opacity: 0.9; }
  %body
    %main
      %h1
        = t :headline, scope: i18n_scope
      %p
        = t :text, scope: i18n_scope
      %button{ type: "button", onclick: "window.location.reload()" }
        = t :cta, scope: i18n_scope
